# Copy to .env only for local development if your launcher or shell loads it.
# Do not commit real .env files.

MOTH_PROJECT_ROOT=app/moth_pi_setup
MOTH_DATA_DIR=app/moth_pi_setup/data
MOTH_DB_PATH=app/moth_pi_setup/data/moth.sqlite
MOTH_UPLOAD_DIR=app/moth_pi_setup/data/uploads

# shadow keeps the original import and records quality output beside it.
# clean imports a cleaned copy after quality review.
LANTERN_IMPORT_QUALITY_MODE=shadow
